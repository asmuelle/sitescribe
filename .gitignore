# Xcode project is generated by XcodeGen from project.yml — never commit it
*.xcodeproj
*.xcworkspace

# Xcode user state & build products
xcuserdata/
DerivedData/
build/
*.xcresult

# Swift Package Manager
.build/
.swiftpm/

# Large on-device model assets (whisper.cpp weights etc.) — fetched, not committed
*.gguf
*.mlmodelc/

# Secrets & local env
.env
.env.*

# macOS
.DS_Store
